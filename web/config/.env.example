# Copy to web/config/.env (or web/.env) and fill in.
# Loaded automatically by uvicorn if you launch via:
#   uvicorn web.backend.app:app --env-file web/config/.env

# Databricks workspace base URL — no trailing slash.
DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com

# OAuth M2M token or PAT for a service principal scoped to the dev workspace.
# Generate via: User Settings → Developer → Access Tokens.
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Absolute volume path to the events landing zone.
# Must match the path Auto Loader / DLT bronze read from.
VOLUME_PATH=/Volumes/dev_main/ecom_bronze/landing/events

# When true, events are written to ./dryrun_events/ on disk instead of
# uploaded to Databricks. Useful for offline development.
DATABRICKS_DRYRUN=false

# Optional: tighten CORS for non-local deployments.
# CORS_ORIGINS=http://localhost:8000,https://your-domain.example

# Optional: log level.
# LOG_LEVEL=INFO
