# Copy to web/config/.env (or web/.env) and fill in.
# Loaded automatically by uvicorn if you launch via:
#   uvicorn web.backend.app:app --env-file web/config/.env

# Databricks workspace base URL — no trailing slash.
DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com

# OAuth M2M token or PAT for a service principal scoped to the dev workspace.
# Generate via: User Settings → Developer → Access Tokens.
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Absolute volume path to the events landing zone.
# Must match the path Auto Loader / DLT bronze read from.
VOLUME_PATH=/Volumes/dev_main/ecom_bronze/landing/events

# When true, events are written to ./dryrun_events/ on disk instead of
# uploaded to Databricks. Useful for offline development.
DATABRICKS_DRYRUN=false

# Optional: tighten CORS for non-local deployments.
# CORS_ORIGINS=http://localhost:8000,https://your-domain.example

# Optional: log level.
# LOG_LEVEL=INFO

# ----- Chat / semantic search ---------------------------------------------
# SQL warehouse used by ProductCatalog and the FAISS row→product_id join.
# SQL_WAREHOUSE_ID=29b258f884d1ac2c

# Databricks Vector Search (tier 1 — preferred when reachable).
# VS_ENDPOINT=bricksshop_vs
# VS_INDEX_NAME=dev_main.ecom_dlt.products_vs_index

# FAISS fallback tier (tier 2). The pointer file is written by the
# `bricksshop-faiss-rebuild` job; the backend hot-reloads when it changes.
# FAISS_VOLUME_PATH=/Volumes/dev_main/ecom_artifacts/faiss
# FAISS_POLL_INTERVAL_S=60
# EMBEDDINGS_TABLE=dev_main.ecom_dlt.product_embeddings

# Embedder — must match what the rebuild job used. Mismatches are
# detected at load time and the FAISS tier refuses to serve.
# EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBED_DIM=384

# ----- Hybrid ranking ------------------------------------------------------
# Re-rank step applied AFTER semantic retrieval (VS / FAISS). The three
# weights are summed into the final_score; defaults below add to 1.0.
# Tune to taste; the ranker will accept any non-negative floats.
# SEMANTIC_WEIGHT=0.60
# PRICE_WEIGHT=0.15
# POPULARITY_WEIGHT=0.25

# Popularity is computed from `events` + `fact_orders` over a rolling
# window. The cache is refreshed in the background — chat replies never
# block on this SQL.
# EVENTS_TABLE=dev_main.ecom_dlt.events
# ORDERS_TABLE=dev_main.ecom_dlt.fact_orders
# POPULARITY_WINDOW_DAYS=7
# POPULARITY_REFRESH_INTERVAL_S=900
